# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/money-maker

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload
MAX_FILE_SIZE=10MB

# Agent Manager Settings
MAX_CONCURRENT=50
SPAWN_DELAY=1000
CLEANUP_INTERVAL=60000
PERSISTENCE_ENABLED=true
SURVIVAL_THRESHOLD=0.2
ELITE_THRESHOLD=0.1
EVALUATION_INTERVAL=300000

# Performance Weights (must sum to 1.0)
WEIGHT_EARNINGS=0.4
WEIGHT_OPPORTUNITIES=0.3
WEIGHT_SUCCESS_RATE=0.2
WEIGHT_STABILITY=0.1

# Agent Type Defaults
CRYPTO_HUNTER_SCAN_INTERVAL=30000
CRYPTO_HUNTER_MAX_RESULTS=10
CRYPTO_HUNTER_MIN_REWARD=10

OPPORTUNITY_SCOUT_SCAN_INTERVAL=45000
OPPORTUNITY_SCOUT_MAX_RESULTS=15
OPPORTUNITY_SCOUT_MIN_REWARD=5

DEVELOPER_TASK_INTERVAL=60000
DEVELOPER_MAX_TASKS=3

MANAGER_EVAL_INTERVAL=300000

# System Limits
MAX_EARNINGS_PER_AGENT_PER_HOUR=10000
MAX_OPPORTUNITIES_PER_AGENT_PER_HOUR=100
MIN_AGENT_LIFETIME=60000

# Opportunity Service Settings
OPPORTUNITY_FREQUENCY=0.3
MAX_OPPORTUNITY_VALUE=1000

# Logging
LOG_LEVEL=info