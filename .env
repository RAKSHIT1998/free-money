# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration - Set to local instance or disable persistence
MONGODB_URI=mongodb://localhost:27017/money-maker

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=*

# File Upload
MAX_FILE_SIZE=10mb

# Agent Manager Settings - MINIMAL FOR FREE LOCAL USAGE
MAX_CONCURRENT=5                    # Reduced from 50 to minimize resources
SPAWN_DELAY=1000                    # Keep default
CLEANUP_INTERVAL=60000              # Keep default (1 minute)
PERSISTENCE_ENABLED=false           # DISABLED - Use in-memory only (no MongoDB needed)

# Survival Algorithm Settings
SURVIVAL_THRESHOLD=0.2              # Keep default (20%)
ELITE_THRESHOLD=0.1                 # Keep default (10%)
EVALUATION_INTERVAL=300000          # Keep default (5 minutes)

# Performance Weights (must sum to 1.0)
WEIGHT_EARNINGS=0.4
WEIGHT_OPPORTUNITIES=0.3
WEIGHT_SUCCESS_RATE=0.2
WEIGHT_STABILITY=0.1

# Agent Type Defaults - REDUCED FREQUENCY TO MINIMIZE RESOURCE USAGE
CRYPTO_HUNTER_SCAN_INTERVAL=120000  # Increased to 2 minutes (from 30s)
CRYPTO_HUNTER_MAX_RESULTS=5         # Reduced from 10
CRYPTO_HUNTER_MIN_REWARD=5          # Reduced from 10

OPPORTUNITY_SCOUT_SCAN_INTERVAL=120000  # Increased to 2 minutes (from 45s)
OPPORTUNITY_SCOUT_MAX_RESULTS=8         # Reduced from 15
OPPORTUNITY_SCOUT_MIN_REWARD=2          # Reduced from 5

DEVELOPER_TASK_INTERVAL=120000      # Increased to 2 minutes (from 60s)
DEVELOPER_MAX_TASKS=2               # Reduced from 3

MANAGER_EVAL_INTERVAL=300000        # Keep default (5 minutes)

# System Limits - REDUCED FOR MINIMAL RESOURCE USAGE
MAX_EARNINGS_PER_AGENT_PER_HOUR=100     # Reduced from 10000
MAX_OPPORTUNITIES_PER_AGENT_PER_HOUR=5  # Reduced from 100
MIN_AGENT_LIFETIME=60000              # Keep 1 minute minimum

# Opportunity Service Settings
OPPORTUNITY_FREQUENCY=0.3             # Keep default
MAX_OPPORTUNITY_VALUE=100             # Reduced from 1000

# Logging
LOG_LEVEL=info